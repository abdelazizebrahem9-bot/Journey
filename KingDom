<script>
  const $ = s => document.querySelector(s);
  const cairoNow = () => new Date(new Date().toLocaleString('en-US', {timeZone: 'Africa/Cairo'}));

  // Clock
  function tick() {
    const now = cairoNow();
    $('#cairo-time').textContent = now.toLocaleTimeString('en-GB', {hour12:false});
  }
  setInterval(tick, 1000); tick();

  // Start date
  const START_KEY = 'kc-start';
  let start = localStorage.getItem(START_KEY);
  const initBtn = $('#init-btn');
  function setStart(d) {
    localStorage.setItem(START_KEY, d.toISOString());
    start = d.toISOString();
    location.reload();
  }
  initBtn.onclick = () => {
    if (!start) setStart(cairoNow());
    else {
      if (confirm('Restart Operation from today? This resets week/day counters.')) {
        localStorage.removeItem(START_KEY);
        setStart(cairoNow());
      }
    }
  };
  if (!start) {
    initBtn.textContent = 'INITIATE';
    initBtn.classList.add('bg-amber-500/20','border-amber-500/30','text-amber-200','hover:bg-amber-500/30');
  } else {
    initBtn.textContent = 'RESTART';
  }

  const startDate = start ? new Date(start) : cairoNow();
  const diffMs = cairoNow() - startDate;
  const dayNum = Math.max(1, Math.floor(diffMs / 86400000) + 1);
  const weekNum = Math.min(12, Math.max(1, Math.ceil(dayNum / 7)));
  $('#stat-day').textContent = Math.min(dayNum,84);
  $('#stat-week').textContent = weekNum;

  // Missions
  const missions = [
    {id:'bbc', label:'BBC 6 Minute English', href:'https://www.bbc.co.uk/learningenglish/english/features/6-minute-english', phase:1},
    {id:'duo', label:'Duolingo • 15 min', href:'https://duolingo.com', phase:1},
    {id:'youglish', label:'YouGlish Shadowing • 5 phrases', href:'https://youglish.com', phase:1},
    {id:'decree', label:'Speak 1 Decree Aloud', desc:'Record 60s voice note', phase:1},
    {id:'fcc', label:'freeCodeCamp • 45 min', href:'https://freecodecamp.org', phase:2},
    {id:'project', label:'Build • Ship progress', desc:'Commit to GitHub', phase:2},
    {id:'cs50', label:'CS50 • 1 lecture (weekly)', href:'https://cs50.harvard.edu/x/', phase:2, weekly:true},
    {id:'leetcode', label:'LeetCode Easy • 1 problem', href:'https://leetcode.com/problemset?difficulty=EASY', phase:3},
    {id:'fireship', label:'Fireship • 1 video', href:'https://fireship.io', phase:3},
    {id:'blog', label:'Dev Blog • 3 lines in English', href:'https://hashnode.com', phase:3},
  ];
  $('#missions-total').textContent = missions.length;

  const todayKey = 'kc-' + cairoNow().toISOString().slice(0,10);
  let saved = {};
  try { saved = JSON.parse(localStorage.getItem(todayKey) || '{}'); } catch {}

  const list = $('#mission-list');
  missions.forEach(m => {
    const row = document.createElement('label');
    row.className = 'group flex items-center gap-3 p-3 rounded-xl bg-zinc-950/70 border border-zinc-800 hover:border-zinc-700 cursor-pointer transition';
    row.innerHTML = `
      <input type="checkbox" data-id="${m.id}" ${saved[m.id] ? 'checked':''}>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="text-[14px] ${saved[m.id] ? 'line-through text-zinc-500':''}">${m.label}</span>
          ${m.weekly ? '<span class="mono text-[9px] px-1.5 py-0.5 rounded bg-zinc-900 border border-zinc-800 text-zinc-400">WEEKLY</span>':''}
          <span class="mono text-[9px] px-1.5 py-0.5 rounded bg-zinc-900 border border-zinc-800 text-zinc-500">P${m.phase}</span>
        </div>
        ${m.desc ? `<div class="text-[11px] text-zinc-500 mt-0.5">${m.desc}</div>`:''}
      </div>
      ${m.href ? `<a href="${m.href}" target="_blank" class="opacity-0 group-hover:opacity-100 text-zinc-500 hover:text-amber-300 transition" onclick="event.stopPropagation()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>`:''}
    `;
    list.appendChild(row);
  });

  function updateProgress() {
    const checks = [...document.querySelectorAll('#mission-list input')];
    const done = checks.filter(c => c.checked).length;
    $('#missions-done').textContent = done;
    const pct = Math.round((done / missions.length) * 100);
    $('#stat-today').textContent = pct;

    // phase bars
    const p1 = missions.filter(m=>m.phase===1);
    const p2 = missions.filter(m=>m.phase===2);
    const p3 = missions.filter(m=>m.phase===3);
    const calc = arr => Math.round((arr.filter(m=>saved[m.id]).length / arr.length)*100);
    const p1pct = calc(p1), p2pct = calc(p2), p3pct = calc(p3);
    $('#p1-pct').textContent = p1pct+'%'; $('#p1-bar').style.width = p1pct+'%';
    $('#p2-pct').textContent = p2pct+'%'; $('#p2-bar').style.width = p2pct+'%';
    $('#p3-pct').textContent = p3pct+'%'; $('#p3-bar').style.width = p3pct+'%';

    // streak
    let streak = 0;
    for (let i=0; i<30; i++) {
      const d = new Date(cairoNow()); d.setDate(d.getDate()-i);
      const key = 'kc-' + d.toISOString().slice(0,10);
      const day = JSON.parse(localStorage.getItem(key) || '{}');
      const dayDone = Object.values(day).filter(Boolean).length;
      if (dayDone >= 6) streak++; else if (i>0) break;
    }
    $('#stat-streak').textContent = streak;
  }

  list.addEventListener('change', e => {
    if (e.target.matches('input[type="checkbox"]')) {
      const id = e.target.dataset.id;
      saved[id] = e.target.checked;
      localStorage.setItem(todayKey, JSON.stringify(saved));
      e.target.closest('label').querySelector('span.text-\[14px\]').classList.toggle('line-through', e.target.checked);
      e.target.closest('label').querySelector('span.text-\[14px\]').classList.toggle('text-zinc-500', e.target.checked);
      updateProgress();
    }
  });
  $('#reset-day').onclick = () => {
    if (confirm('Reset today\'s missions?')) {
      localStorage.removeItem(todayKey);
      saved = {};
      document.querySelectorAll('#mission-list input').forEach(i=>i.checked=false);
      document.querySelectorAll('#mission-list span.text-\[14px\]').forEach(s=>s.classList.remove('line-through','text-zinc-500'));
      updateProgress();
    }
  };
  updateProgress();

  // Timeline
  const timeline = $('#timeline');
  [0,4,8,12].forEach((w,i)=>{
    const d = new Date(startDate); d.setDate(d.getDate() + w*7);
    const done = weekNum > w || (w===0);
    const el = document.createElement('div');
    el.className = 'text-center';
    el.innerHTML = `
      <div class="relative z-10 mx-auto w-[28px] h-[28px] rounded-full flex items-center justify-center border ${done ? 'bg-amber-500/20 border-amber-400/50 text-amber-200':'bg-zinc-900 border-zinc-700 text-zinc-500'}">
        <span class="mono text-[11px] font-semibold">${w}</span>
      </div>
      <div class="mt-2 mono text-[10px] ${done?'text-zinc-300':'text-zinc-600'}">WEEK ${w}</div>
      <div class="mono text-[10px] text-zinc-500">${d.toLocaleDateString('en-GB',{day:'2-digit', month:'short'})}</div>
    `;
    timeline.appendChild(el);
  });

  // Decrees
  const decrees = [
    'Speak like a king. Code like a weapon.',
    'Output daily, or disappear.',
    'English opens doors. Code builds kingdoms.',
    'No zero days in Cairo.',
    'Ship one thing. Every week.',
    'Shadowing > passive listening.',
    'Results only. Excuses burn.',
  ];
  $('#decree').textContent = decrees[new Date().getDate() % decrees.length];
</script>
</body>
</html>
